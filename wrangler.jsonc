{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "limocon-app-portal-site",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": ".",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/lt-google-review-booster", "/lt-google-review-booster/*"],
  },
}
